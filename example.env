# ====================================
# ShopWise (Giftstacc) — current platform
# ====================================
# Login is mobile + 4-digit SMS OTP (no password). See SHOPWISE_FLOW.md.
MOBILE=your_mobile_number
SHOPWISE_BASE_URL=https://shopwise.giftstacc.com
SHOPWISE_LOGIN_URL=https://sso.ai-loyalty.com/Login/GIFT-AMX-PRDSTACC-20251008
# Product to buy (default = Amazon Pay E-Gift Voucher). Find others via the productId in /giftcard?productId=...
PRODUCT_ID=gko2OEEac6Y24dmH/bBa7g==
# Denomination plan: amountXqty, comma-separated. e.g. "1000x1" or "1000x1,500x1" (= one ₹1,500 transaction)
DENOMINATIONS=1000x1
# Stage 3 (payment gateway) is not yet verified; CVV used only by the best-effort payment handler.
PAYMENT_CARD_CVV=
HEADLESS=true

# ====================================
# AmEx Gyftr Credentials (LEGACY — retired platform, kept for reference)
# ====================================
EMAIL=your_email@example.com
MEMBERSHIP_CARD_CVV=123
GOLDCHARGE_CARD_CVV=456
USE_GOLDCHARGE_CARD=false

# ====================================
# n8n Configuration
# ====================================
# For Docker: Use container name
N8N_BASE_URL=http://n8n:5678
# For Dokploy: Use your public URL
# N8N_BASE_URL=https://your-n8n-domain.com

N8N_HOST=your-n8n-domain.com
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false

# ====================================
# Dokploy Domain Configuration
# ====================================
# Set these to your actual domains
N8N_DOMAIN=n8n.yourdomain.com
PLAYWRIGHT_DOMAIN=playwright.yourdomain.com

WEBHOOK_PATH=/webhook/ios-sms
GENERIC_TIMEZONE=Asia/Kolkata

# ====================================
# Swiggy Voucher Auto-Claim (Optional)
# ====================================
SWIGGY_VOUCHER_CLAIM_URL=https://chkout.swiggy.com/swiggymoney/voucher/claim
SWIGGY_DEVICE_ID=your_device_id
SWIGGY_TID=your_tid
SWIGGY_TOKEN=your_swiggy_token

# ====================================
# Playwright Service Configuration
# ====================================
PLAYWRIGHT_HOST_PORT=3010
TZ=Asia/Kolkata
